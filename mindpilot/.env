# ============================================================
# MindPilot — LLM 接口配置
# 使用方法：copy config.example.env .env  然后填入真实 Key
# ============================================================

# ── API Key ─────────────────────────────────────────────────
LLM_API_KEY=sk-sp-20e5e96145434a1680c9ff685e03fc69

# ── 接入点 ───────────────────────────────────────────────────
LLM_BASE_URL=https://coding.dashscope.aliyuncs.com/v1

# ── 模型选择（必须从下方可用列表中选择）─────────────────────
#
# 百炼 Coding Plan 当前可用模型：
#
#   千问系列：
#     qwen3.5-plus          通用对话，均衡速度与质量
#     qwen3-max-2026-01-23  最高质量，深度思考（规划效果最好）
#     qwen3-coder-next      代码专用，最新版
#     qwen3-coder-plus      代码专用，稳定版  ← CODE_MODEL 推荐
#
#   智谱系列：
#     glm-5                 通用对话，深度思考  ← LLM_MODEL 可选
#     glm-4.7               通用对话，较快
#
#   其他：
#     kimi-k2.5             Kimi，视觉理解
#     MiniMax-M2.5          MiniMax
#
# ⚠ 模型名拼写注意：
#   正确：qwen3-coder-plus（有"3"）← 带3
#   错误：qwen-coder-plus （无"3"）← 不带3，会报 400 错误

# 通用对话模型（规划 / 文献摘要 / 评估模块使用）
LLM_MODEL=glm-5

# 代码生成专用模型（CodeAgent 专用）
CODE_MODEL=qwen3-coder-plus

# 这个环境变量用于开启或关闭人工审核，开启后，在 Agent 规划阶段会暂停并提示用户输入，允许用户干预路径选择。
HUMAN_IN_THE_LOOP=true
# ── 关于响应时间的说明 ────────────────────────────────────────
#
# Agent 规划阶段（ToT）会对 3 条研究路径各做一次评分，
# 加上路径生成和任务分解，共需约 6~9 次 LLM 调用。
#
# 使用 glm-5 时每次调用约 30~90 秒（深度思考模型），
# 因此规划阶段总耗时约 4~12 分钟，这是正常现象，
# 换来的是更高质量的研究路径选择。
#
# 若希望加快速度（略微降低规划质量），可改用：
#   LLM_MODEL=glm-4.7        （智谱较快版本）
#   LLM_MODEL=qwen3.5-plus   （千问均衡版本）

# ── 代理（留空=自动探测；需要时填写）───────────────────────
# LLM_PROXY_URL=http://127.0.0.1:7890
LLM_PROXY_URL=
